{
  "version": 2,
  "builds": [
    {
      "src": "backend/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["frontend/dist/**"]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "backend/index.js" }
  ],
  "functions": {
    "backend/index.js": {
      "runtime": "nodejs22.x",
      "maxDuration": 30
    }
  }
}
